# --------------------------------------------------------------
# Required to make Ask Petro chat respond live (otherwise it falls
# back to canned answers from the source code).
# --------------------------------------------------------------
OPENAI_API_KEY=sk-...

# Optional override (default: gpt-5-mini, matches Insight Draft)
# OPENAI_MODEL=gpt-5-mini

# --------------------------------------------------------------
# Required for the contact form to deliver email (otherwise the
# dialog returns "email Petro directly").
# Sign up at https://resend.com (free tier: 100 emails/day).
# --------------------------------------------------------------
RESEND_API_KEY=re_...

# Optional: override the "from" address. Must be a verified Resend
# domain. Defaults to Resend's sandbox onboarding@resend.dev which
# works without any DNS setup but lands in spam more often.
# RESEND_FROM_EMAIL=Portfolio <noreply@petropavlov.com>

# Optional: override where contact-form messages are delivered.
# CONTACT_TO_EMAIL=petromilpavlov@gmail.com
