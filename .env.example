# --------------------------------------------------------------
# Required to make Ask Petro chat respond live (otherwise it falls
# back to canned answers from the source code).
# --------------------------------------------------------------
OPENAI_API_KEY=sk-...

# Optional override (default: gpt-5-mini, matches Insight Draft)
# OPENAI_MODEL=gpt-5-mini

# --------------------------------------------------------------
# Required for the contact form to deliver email (otherwise the
# dialog returns "email Petro directly").
# Sign up at https://resend.com (free tier: 100 emails/day).
# --------------------------------------------------------------
RESEND_API_KEY=re_...

# Optional: override the "from" address. Must be a verified Resend
# domain. Defaults to Resend's sandbox onboarding@resend.dev which
# works without any DNS setup but lands in spam more often.
# RESEND_FROM_EMAIL=Portfolio <noreply@petropavlov.dev>

# Optional: override where contact-form messages are delivered.
# CONTACT_TO_EMAIL=petromilpavlov@gmail.com

# --------------------------------------------------------------
# Pulse analytics — required to make tracking + dashboards work.
# --------------------------------------------------------------

# Postgres connection string. Auto-set by Vercel when you provision
# Postgres via Storage tab → Create → Postgres. For other providers
# (Neon, Supabase, RDS, local) set this manually.
# POSTGRES_URL=postgres://...

# Random 32+ byte hex string. Used to derive the daily-rotating salt
# for session hashing. Generate with: openssl rand -hex 32
# Without this, Pulse uses a fallback secret — fine for local dev but
# unsafe in production (it would let an attacker who guesses the
# fallback link past-day session hashes back to live IPs).
ANALYTICS_SALT_SECRET=

# Password for the /admin/analytics and /admin/speed dashboards.
# Username is always "admin". Pick a strong one.
ANALYTICS_ADMIN_PASSWORD=
